PORT=3000

# LINE Messaging API (チャットBot・配信用のキー)
LINE_CHANNEL_ID=your_messaging_channel_id
LINE_CHANNEL_SECRET=your_messaging_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_messaging_channel_access_token

# LINE Login (LIFF管理画面用のID)
LIFF_ID=your_liff_id

# OpenAI API (自動プロファイリング・メッセージ生成用)
OPENAI_API_KEY=your_openai_api_key
